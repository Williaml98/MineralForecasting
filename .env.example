# PostgreSQL (local installation)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mineral_forecasting
DB_USERNAME=postgres
DB_PASSWORD=yourpassword

# Admin seed account
ADMIN_EMAIL=admin@bfmining.com
ADMIN_PASSWORD=Admin@12345

# JWT
JWT_SECRET=replace-with-a-secure-256-bit-random-string
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# Gmail SMTP — use a Google App Password (not your Gmail password)
# To generate: Google Account → Security → 2-Step Verification → App Passwords
MAIL_USERNAME=yourgmail@gmail.com
MAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_FROM=noreply@bfmining.com

# ML Service
ML_SERVICE_URL=http://localhost:8000

# Backend URL used by Next.js server-side proxy (not exposed to browser)
BACKEND_URL=http://localhost:8080
