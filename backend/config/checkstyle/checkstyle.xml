<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Minimal Checkstyle configuration for the BF Mining Forecasting backend.
    Enforces:
      - No tab characters (spaces only)
      - Maximum line length of 120 characters
      - Javadoc on all public methods and classes
-->
<module name="Checker">

    <!-- Enforce Unix-style line endings -->
    <property name="fileEncoding" value="UTF-8"/>

    <!-- Exclude generated sources and test resources -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="module\-info\.java$"/>
    </module>

    <!-- ===== File-level checks ===== -->

    <!-- No tab characters anywhere in source files -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- Maximum line length of 120 characters -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>

    <!-- Trailing whitespace -->
    <module name="RegexpSingleline">
        <property name="format" value="\s+$"/>
        <property name="minimum" value="0"/>
        <property name="maximum" value="0"/>
        <property name="message" value="Line has trailing spaces."/>
    </module>

    <!-- ===== Tree Walker checks (per-token AST) ===== -->
    <module name="TreeWalker">

        <!-- Javadoc on public types (classes, interfaces, enums) -->
        <module name="JavadocType">
            <property name="scope" value="public"/>
        </module>

        <!-- Javadoc on public methods -->
        <module name="JavadocMethod">
            <property name="accessModifiers" value="public"/>
            <property name="allowMissingParamTags" value="false"/>
            <property name="allowMissingReturnTag" value="false"/>
        </module>

        <!-- Javadoc on public variables/fields -->
        <module name="JavadocVariable">
            <property name="scope" value="public"/>
        </module>

        <!-- Ensure Javadoc paragraphs are well-formed -->
        <module name="JavadocParagraph"/>

        <!-- ===== Import checks ===== -->

        <!-- Disallow wildcard imports -->
        <module name="AvoidStarImport"/>

        <!-- Disallow unused imports -->
        <module name="UnusedImports"/>

        <!-- ===== Whitespace and formatting ===== -->

        <!-- No whitespace after certain tokens -->
        <module name="NoWhitespaceAfter"/>

        <!-- No whitespace before certain tokens -->
        <module name="NoWhitespaceBefore"/>

        <!-- Ensure operators are at end of wrapped lines, not start -->
        <module name="OperatorWrap"/>

        <!-- Opening brace on same line -->
        <module name="LeftCurly"/>

        <!-- Closing brace alone on a line -->
        <module name="RightCurly"/>

        <!-- ===== Naming conventions ===== -->

        <!-- Constants must be UPPER_SNAKE_CASE -->
        <module name="ConstantName"/>

        <!-- Local variables must be camelCase -->
        <module name="LocalVariableName"/>

        <!-- Method names must be camelCase -->
        <module name="MethodName"/>

        <!-- Package names must be all lowercase -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- Type names must start with uppercase -->
        <module name="TypeName"/>

        <!-- ===== Code quality ===== -->

        <!-- Disallow empty catch blocks without a comment -->
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignore"/>
        </module>

        <!-- Require braces around single-line control flow statements -->
        <module name="NeedBraces"/>

        <!-- Disallow System.out.println in favour of proper logging -->
        <module name="Regexp">
            <property name="format" value="System\.out\.println"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="Use a logger instead of System.out.println."/>
        </module>

    </module>

</module>
