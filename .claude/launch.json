{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Backend (Spring Boot)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "mvnw.cmd spring-boot:run"],
      "cwd": "backend",
      "port": 8080
    },
    {
      "name": "ML Service (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--reload", "--port", "8000"],
      "cwd": "ml-service",
      "port": 8000
    }
  ]
}
